# ==========================
# FastAPI runtime
# ==========================
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:5500,http://127.0.0.1:5500
# Generate with: openssl rand -hex 64
JWT_SECRET_KEY=change-me-generate-a-strong-secret

# ==========================
# SQL Server
# ==========================
SQL_DRIVER=ODBC Driver 18 for SQL Server
SQL_SERVER=localhost
SQL_PORT=1433
SQL_DATABASE=AttendanceAI
SQL_USER=sa
SQL_PASSWORD=YourStrong!Passw0rd
SQL_TRUST_SERVER_CERT=yes
# Optional override (if provided, this wins):
# SQL_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=localhost,1433;DATABASE=AttendanceAI;UID=sa;PWD=YourStrong!Passw0rd;TrustServerCertificate=yes

# ==========================
# AI dual-mode switch
# ==========================
# CPU mode (default): uses face_recognition with HOG detector
# GPU mode: uses InsightFace + CUDA provider
AI_MODE=cpu
CPU_FACE_DETECT_MODEL=hog
CPU_DISTANCE_THRESHOLD=0.45
GPU_COSINE_THRESHOLD=0.55

# ==========================
# Recognition behavior
# ==========================
RECOGNITION_FRAME_STRIDE=8
RECOGNITION_EVENT_COOLDOWN_SEC=20

# ==========================
# Anti-spoofing (CNN PAD)
# ==========================
# MiniFASNet ONNX ensemble.  Run once before first startup:
#   pip install "torch==2.1.*" --index-url https://download.pytorch.org/whl/cpu
#   python scripts/convert_pad_models.py
# If the .onnx files are missing the detector is disabled with a warning log.
ANTISPOOF_ENABLED=true
# Per-frame live probability threshold (0..1).  Lower = more permissive.
ANTISPOOF_LIVE_THRESHOLD=0.55
# Sliding window size in frames for temporal aggregation.
ANTISPOOF_WINDOW_FRAMES=6
# How many of the window's frames must be live to mark attendance.
ANTISPOOF_REQUIRED_LIVE_FRAMES=4
# Seconds before an idle track is evicted from the temporal cache.
ANTISPOOF_TRACK_TTL_SEC=8.0

# ==========================
# SMTP
# ==========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_account@example.com
SMTP_PASSWORD=app-password-or-secret
SMTP_FROM=Attendance Bot <your_account@example.com>
SMTP_USE_TLS=true
SMTP_DRY_RUN=true

# Optional: use Resend over HTTPS (recommended if SMTP ports are blocked)
# EMAIL_PROVIDER=smtp           # or resend_api
# RESEND_API_KEY=re_xxx
# RESEND_API_URL=https://api.resend.com/emails
# RESEND_TIMEOUT_SEC=15

# ==========================
# Student portal
# ==========================
FRONTEND_URL=https://your-domain.com
